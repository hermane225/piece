# Database (PostgreSQL - Render)
DATABASE_URL="postgresql://username:password@host:5432/database"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# SMTP (mot de passe oublié)
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT="587"
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"
SMTP_FROM="no-reply@piece-rare.ci"

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Server
PORT=3000

# CORS (prod)
# Use FRONTEND_URL for a single origin or FRONTEND_URLS for a comma-separated list
FRONTEND_URL="https://piece-rare.ci"
# FRONTEND_URLS="https://piece-rare.ci,https://piece.blueredc.com,http://localhost:8081"

