generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum Condition {
  NEUF
  QUASI_NEUF
  RECONDITIONNE
  SECONDE_MAIN
}

enum Category {
  PHONE
  PC
  AUTO_MOTO
  AUTO_PARTS
  MOTO_PARTS
  AUTO_ACCESSORIES
  AUTO_EQUIPMENT
  APPLIANCES
  FRIDGE_PARTS
  WASHING_MACHINE_PARTS
  AC_PARTS
  MICROWAVE_PARTS
  HOME_DIY
  TOOLS
  ELECTRICAL_MATERIAL
  PLUMBING
  CARPENTRY
  ENERGY_INDUSTRY
  GENERATORS
  SOLAR_PANELS
  INDUSTRIAL_BATTERIES
  INDUSTRIAL_MACHINE_PARTS
  MULTIMEDIA_GAMING
  CONSOLES
  CONTROLLERS
  CONSOLE_PARTS
  GAMING_ACCESSORIES
  OTHER_VEHICLES
  BICYCLE
  SCOOTER
  VARIOUS_PARTS
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String   @unique
  password  String
  city      String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts Post[]

  @@map("users")
}

model Post {
  id          String    @id @default(uuid())
  title       String
  description String
  price       Float
  condition   Condition
  brand       String
  model       String
  category    Category
  city        String
  images      String[]
  isApproved  Boolean   @default(false)
  boostedUntil DateTime? // Date jusqu'à laquelle l'annonce est boostée
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("posts")
}

model Banner {
  id        String   @id @default(uuid())
  title     String
  image     String
  comment   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banners")
}
